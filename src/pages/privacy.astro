---
import BaseLayout from '@layouts/BaseLayout.astro'
import GlitchText from '@components/GlitchText.tsx'
import { BUSINESS_NAME, CURRENT_YEAR, TAGLINE } from '@data/site'
const lastUpdatedHuman = new Date().toLocaleDateString()
---
<BaseLayout title="Privacy Policy" description="Privacy policy for the business portfolio">
  <main class="min-h-screen relative z-10 px-4 sm:px-6 lg:px-8 py-10">
    <section class="max-w-5xl mx-auto">
      <div class="flex items-center gap-4 mb-6">
        <div>
          <a href="/" aria-label="Go to homepage" class="inline-block">
            <GlitchText text={BUSINESS_NAME} className="text-3xl sm:text-5xl font-bold" client:visible />
          </a>
          <p class="mt-1 text-sm sm:text-base">{TAGLINE}</p>
        </div>
      </div>
      <div class="neon-border neon-hover bg-black/80 rounded-md p-4 sm:p-6">
        <h1 class="text-xl sm:text-2xl mb-3">Privacy Policy</h1>
        <div class="space-y-4 text-sm sm:text-base">
          <p>Last Updated: <span class="font-mono">{lastUpdatedHuman}</span></p>
          <p>This website does not collect personal information beyond standard hosting logs. No tracking cookies or third‑party analytics are used.</p>
        </div>
      </div>
      <footer class="text-center text-xs sm:text-sm mt-6">
        <span class="bg-black/80 rounded-md px-2 py-1 inline-block">© {CURRENT_YEAR} {BUSINESS_NAME}. All rights reserved. · <a href="/" class="neon-border neon-hover bg-black/80 rounded-md px-2 py-1 inline-block">Home</a></span>
      </footer>
    </section>
  </main>
</BaseLayout>
